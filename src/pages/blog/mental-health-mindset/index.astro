---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

const articles = [
  {
    title: 'The Science of Discipline: Why Motivation is a Lie',
    description: 'Motivation is unreliable. Here\'s the neuroscience of habit formation and how to build systems that make discipline automatic.',
    pubDate: new Date('2026-03-07'),
    slug: 'science-of-discipline',
    category: 'mental-health-mindset',
    readTime: '10 min read',
  },
];
---

<BaseLayout
  title="Mental Health & Mindset"
  description="The psychology of performance, discipline, resilience, and mental wellness."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-4">
      <a href="/blog" class="text-brand-muted text-sm hover:text-brand-accent transition-colors">← All Articles</a>
    </div>
    <div class="flex items-center gap-3 mb-4">
      <span class="text-4xl">🧠</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-amber-400">Mental Health & Mindset</h1>
    </div>
    <p class="text-brand-muted text-lg mb-10">The foundation of everything — psychology, habits, and performance mindset.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map(article => <ArticleCard {...article} />)}
    </div>
  </div>
</BaseLayout>
