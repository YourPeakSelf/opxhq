---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ArticleCard from '../components/ArticleCard.astro';

const categories = [
  {
    label: 'Workouts & Training',
    href: '/blog/workouts-training',
    icon: '🏋️',
    color: 'border-red-800/50 hover:border-red-500/70',
    textColor: 'text-red-400',
    desc: 'Programs, technique, and performance',
  },
  {
    label: 'Peptides & Supplements',
    href: '/blog/peptides-supplements',
    icon: '🧬',
    color: 'border-purple-800/50 hover:border-purple-500/70',
    textColor: 'text-purple-400',
    desc: 'What works, what\'s safe, what\'s hype',
  },
  {
    label: 'Skincare & Looksmaxing',
    href: '/blog/skincare-looksmaxing',
    icon: '✨',
    color: 'border-pink-800/50 hover:border-pink-500/70',
    textColor: 'text-pink-400',
    desc: 'Evidence-based aesthetics for everyone',
  },
  {
    label: 'Diet & Nutrition',
    href: '/blog/diet-nutrition',
    icon: '🥗',
    color: 'border-green-800/50 hover:border-green-500/70',
    textColor: 'text-green-400',
    desc: 'Fuel that actually performs',
  },
  {
    label: 'Biohacking & Longevity',
    href: '/blog/biohacking-longevity',
    icon: '⚡',
    color: 'border-cyan-800/50 hover:border-cyan-500/70',
    textColor: 'text-cyan-400',
    desc: 'Live longer, perform better',
  },
  {
    label: 'Mental Health & Mindset',
    href: '/blog/mental-health-mindset',
    icon: '🧠',
    color: 'border-amber-800/50 hover:border-amber-500/70',
    textColor: 'text-amber-400',
    desc: 'The foundation of everything',
  },
];

// Sample featured articles — replace with content collection queries
const featuredArticles = [
  {
    title: 'BPC-157: The Complete Guide to This Healing Peptide',
    description: 'Everything you need to know about BPC-157 — mechanism of action, dosing protocols, injury recovery applications, and what the research actually says.',
    pubDate: new Date('2026-03-13'),
    slug: 'bpc-157-complete-guide',
    category: 'peptides-supplements',
    readTime: '12 min read',
  },
  {
    title: 'The Optimal Morning Routine for Body Composition',
    description: 'Stack your morning habits to prime fat burning, maximize muscle protein synthesis, and set your hormones up for the day.',
    pubDate: new Date('2026-03-12'),
    slug: 'optimal-morning-routine-body-composition',
    category: 'workouts-training',
    readTime: '8 min read',
  },
  {
    title: 'The Male Skincare Stack That Actually Works',
    description: 'A no-nonsense, evidence-based skincare routine for men — morning, evening, and the actives worth spending money on.',
    pubDate: new Date('2026-03-11'),
    slug: 'male-skincare-stack',
    category: 'skincare-looksmaxing',
    readTime: '7 min read',
  },
];
---

<BaseLayout
  title="OPX — Optimize Perform Excel"
  description="Evidence-based content for fitness, nutrition, peptides, skincare, and human optimization. No fluff. Just what works."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand-accent/5 via-transparent to-transparent pointer-events-none" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
      <div class="inline-flex items-center gap-2 bg-brand-accent/10 border border-brand-accent/20 rounded-full px-4 py-1.5 text-brand-accent text-xs font-semibold uppercase tracking-wider mb-8">
        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full animate-pulse" />
        Optimize Perform Excel
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight tracking-tight mb-6">
        Optimize Your<br />
        <span class="text-gradient">Body & Mind</span>
      </h1>

      <p class="text-brand-muted text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Fitness, nutrition, peptides, skincare, and longevity — all in one place.
        No bro-science. No fluff. Just what actually works.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a href="/blog" class="btn-primary px-8 py-3.5 text-base">
          Browse Articles
        </a>
        <a href="/newsletter" class="btn-outline px-8 py-3.5 text-base">
          Free Newsletter
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-wrap justify-center gap-8 text-center">
        {[
          { val: '100+', label: 'Articles' },
          { val: '6', label: 'Topics' },
          { val: 'Weekly', label: 'Newsletter' },
        ].map(stat => (
          <div>
            <div class="text-2xl font-bold text-white">{stat.val}</div>
            <div class="text-brand-muted text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-heading">Browse by Topic</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {categories.map(cat => (
        <a
          href={cat.href}
          class={`card p-5 border ${cat.color} transition-all duration-200 group`}
        >
          <div class="text-2xl mb-3">{cat.icon}</div>
          <h3 class={`font-bold text-sm mb-1 ${cat.textColor} group-hover:opacity-80`}>
            {cat.label}
          </h3>
          <p class="text-brand-muted text-xs leading-relaxed hidden sm:block">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-heading">Latest Articles</h2>
      <a href="/blog" class="text-brand-accent text-sm font-semibold hover:underline">View all →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredArticles.map(article => (
        <ArticleCard {...article} />
      ))}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <NewsletterSignup
      variant="inline"
      heading="The OPX Weekly — Free"
      subheading="Get the best of fitness, nutrition, peptides, and optimization in your inbox every week. Cut through the noise."
    />
  </section>

  <!-- Trust Signals -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-brand-border">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      {[
        {
          icon: '🔬',
          title: 'Research-Backed',
          desc: 'We cite primary sources and cut through misinformation.',
        },
        {
          icon: '⚡',
          title: 'Actionable',
          desc: 'Every article ends with clear, practical takeaways.',
        },
        {
          icon: '🚫',
          title: 'No Sponsorship Bias',
          desc: 'We call out what doesn\'t work, even when it\'s popular.',
        },
      ].map(item => (
        <div class="p-6">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="font-bold text-white mb-2">{item.title}</h3>
          <p class="text-brand-muted text-sm">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
