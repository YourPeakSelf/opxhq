---
const navLinks = [
  { label: 'Articles', href: '/blog' },
  { label: 'Newsletter', href: '/newsletter' },
  { label: 'Resources', href: '/resources' },
  { label: 'About', href: '/about' },
];
---

<header class="sticky top-0 z-50 bg-brand-bg/90 backdrop-blur-md border-b border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-brand-accent rounded-md flex items-center justify-center">
          <span class="text-brand-bg font-black text-sm">OPX</span>
        </div>
        <span class="font-bold text-white text-lg tracking-tight hidden sm:block">OPX</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-brand-muted hover:text-white text-sm font-medium transition-colors duration-150"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a href="/newsletter" class="btn-primary text-xs sm:text-sm px-4 py-2">
          Join Newsletter
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-brand-muted hover:text-white transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-brand-border mt-0 pt-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block py-2.5 text-brand-muted hover:text-white text-sm font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
