---
import CategoryBadge from './CategoryBadge.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
  heroImage?: string;
  readTime?: string;
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  slug,
  category,
  heroImage,
  readTime = '5 min read',
  featured = false,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<article class={`card group hover:border-brand-accent/40 transition-all duration-200 hover:glow-sm ${featured ? 'md:flex' : ''}`}>
  {heroImage && (
    <div class={`overflow-hidden ${featured ? 'md:w-2/5 flex-shrink-0' : 'aspect-video'}`}>
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}

  <div class="p-6 flex flex-col justify-between">
    <div>
      <div class="mb-3">
        <CategoryBadge category={category} size="sm" />
      </div>
      <h3 class={`font-bold text-white leading-tight mb-3 group-hover:text-brand-accent transition-colors ${featured ? 'text-xl md:text-2xl' : 'text-lg'}`}>
        <a href={`/blog/${category}/${slug}`}>{title}</a>
      </h3>
      <p class="text-brand-muted text-sm leading-relaxed line-clamp-3">{description}</p>
    </div>

    <div class="flex items-center justify-between mt-4 pt-4 border-t border-brand-border">
      <div class="flex items-center gap-2 text-brand-muted text-xs">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span>·</span>
        <span>{readTime}</span>
      </div>
      <a
        href={`/blog/${category}/${slug}`}
        class="text-brand-accent text-xs font-semibold hover:underline"
      >
        Read →
      </a>
    </div>
  </div>
</article>
