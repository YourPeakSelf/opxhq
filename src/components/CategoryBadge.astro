---
export interface Props {
  category: string;
  size?: 'sm' | 'md';
}

const { category, size = 'md' } = Astro.props;

const categoryMap: Record<string, { label: string; color: string; bg: string; border: string }> = {
  'workouts-training': {
    label: 'Workouts & Training',
    color: 'text-red-400',
    bg: 'bg-red-950/50',
    border: 'border-red-800/50',
  },
  'peptides-supplements': {
    label: 'Peptides & Supplements',
    color: 'text-purple-400',
    bg: 'bg-purple-950/50',
    border: 'border-purple-800/50',
  },
  'skincare-looksmaxing': {
    label: 'Skincare & Looksmaxing',
    color: 'text-pink-400',
    bg: 'bg-pink-950/50',
    border: 'border-pink-800/50',
  },
  'diet-nutrition': {
    label: 'Diet & Nutrition',
    color: 'text-green-400',
    bg: 'bg-green-950/50',
    border: 'border-green-800/50',
  },
  'biohacking-longevity': {
    label: 'Biohacking & Longevity',
    color: 'text-cyan-400',
    bg: 'bg-cyan-950/50',
    border: 'border-cyan-800/50',
  },
  'mental-health-mindset': {
    label: 'Mental Health & Mindset',
    color: 'text-amber-400',
    bg: 'bg-amber-950/50',
    border: 'border-amber-800/50',
  },
};

const cat = categoryMap[category] ?? {
  label: category,
  color: 'text-brand-accent',
  bg: 'bg-brand-surface',
  border: 'border-brand-border',
};

const sizeClass = size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-xs px-3 py-1';
---

<a
  href={`/blog/${category}`}
  class={`inline-flex items-center ${sizeClass} rounded-full font-semibold uppercase tracking-wider border ${cat.color} ${cat.bg} ${cat.border} hover:opacity-80 transition-opacity`}
>
  {cat.label}
</a>
